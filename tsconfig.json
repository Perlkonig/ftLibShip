{
    "include": ["src/**/*.d.ts", "src/**/*.ts", "src/**/*.js"],
    "compilerOptions": {
        "target": "es2018",
        "module": "NodeNext",
        "moduleResolution": "NodeNext",
        "declaration": true,
        "sourceMap": false,
        "outDir": "dist",
        "strict": true,
        "esModuleInterop": true,
        "strictNullChecks": true,
        "resolveJsonModule": true,
        "skipLibCheck": true
    }
}
